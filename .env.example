# Skopiuj ten plik do `.env` i uzupełnij własnymi wartościami.
# Plik `.env` NIE jest commitowany do repozytorium (jest w .gitignore).

# Port serwera (opcjonalnie, domyślnie 3000)
PORT=3000

# Klucz API CSFloat (opcjonalny, ale bez niego CSFloat często zwraca HTTP 429).
# Wygeneruj go w ustawieniach konta na https://csfloat.com
CSFLOAT_API_KEY=

# Dane API Skinport (opcjonalne — używane tylko jeśli włączysz autoryzację feedu).
SKINPORT_CLIENT_ID=
SKINPORT_CLIENT_SECRET=
